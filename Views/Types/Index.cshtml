@model List<CadastralManagementSystem.Models.CadastralObjectType>
@{
    ViewBag.Title = "Справочник типов объектов";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>@ViewBag.Title</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<p>
    <a href="/Types/Create" class="btn btn-primary">Добавить тип</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Название</th>
            <th>Описание</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var type in Model)
        {
            <tr>
                <td>@type.Id</td>
                <td>@type.Name</td>
                <td>@type.Description</td>
                <td>
                    <a href="/Types/Edit/@type.Id" class="btn btn-warning btn-sm">Редактировать</a>
                    <a href="/Types/Delete/@type.Id" class="btn btn-danger btn-sm">Удалить</a>
                </td>
            </tr>
        }
    </tbody>
</table>